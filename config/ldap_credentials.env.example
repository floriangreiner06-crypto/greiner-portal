# LDAP/Active Directory Konfiguration
# ====================================
# Kopiere diese Datei zu ldap_credentials.env und passe die Werte an

# AD-Server (FQDN oder IP)
LDAP_SERVER=dein-ad-server.de

# Port (389 für LDAP, 636 für LDAPS)
LDAP_PORT=389

# SSL verwenden? (True/False)
LDAP_USE_SSL=False

# Service-Account für LDAP-Bind
LDAP_BIND_DN=svc_portal@dein-domain.de

# Service-Account-Passwort
LDAP_BIND_PASSWORD=dein-passwort-hier

# Base-DN für Suche (z.B. DC=dein-domain,DC=de)
LDAP_BASE_DN=DC=dein-domain,DC=de

# Zertifikat-Validierung (True/False)
LDAP_VALIDATE_CERT=False
